          if (!items.length) {
            scheduledList.innerHTML = '<div style="color:var(--crm-text-secondary);font-size:.85rem;">Nenhuma mensagem agendada.</div>';
            return;
          }
          scheduledList.innerHTML = items.map(it => {
            const dt = new Date(it.sendAtIso);
            const future = dt.getTime() > Date.now();
            const canCancel = it.status === 'scheduled' && future;
            return `
              <div class="crm-history-item" data-schedule-id="${it.id}">
                <time>${Number.isFinite(dt.getTime()) ? dt.toLocaleString() : it.sendAtIso}</time>
                <div style="margin:.25rem 0 .5rem 0"><b>Status:</b> ${it.status}</div>
