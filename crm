    const sb = findSidebar(); if (!sb) return null;
    const uls = Array.from(sb.querySelectorAll('ul'));
    for (const ul of uls) {
      const hasAll = Array.from(ul.children).some(li => __norm(li.textContent) === 'todas as conversas');
      if (hasAll) return ul;
    }
    return null;
  }
  function findAllConversationsItem() {
    const ul = findConversationsList(); if (!ul) return null;
    return Array.from(ul.children).find(li => __norm(li.textContent) === 'todas as conversas') || null;
  }

