        catch (e) { console.warn('Falha ao aplicar label na conversa', e); }
      },

      applyConversationToCards(contactId, conversationId) {
        if (!Number.isFinite(contactId) || !Number.isFinite(conversationId)) return;
        const cKey = String(contactId); const convVal = String(conversationId);
        let ok = false;
        Object.values(this.data).forEach(column => {
          column.cards.forEach(card => {
            if (String(card.contactId) === cKey) { card.conversationId = convVal; card.id = card.contactId || card.conversationId || card.cliente; ok = true; }
          });
        });
        if (ok) this.saveLocal();
      },

      getStageForContact(contactId) {
        if (!Number.isFinite(contactId)) return null;
        const key = String(contactId);
        for (const column of Object.values(this.data)) if (column.cards.some(card => String(card.contactId) === key)) return column.id;
        return null;
      },
      getStageForConversation(conversationId) {
        if (!Number.isFinite(conversationId)) return null;
        const key = String(conversationId);
        for (const column of Object.values(this.data)) if (column.cards.some(card => String(card.conversationId) === key)) return column.id;
        return null;
      },

      // ===== Sync =====
      async syncFromAPI() {
        this.updateAccountIdFromLocation(false);
        const fresh = this.getInitialData();
        const cardsByContact = new Map();
        const conversationCards = [];
        const convExtraFilter = this.inboxFilterId ? { inbox_id: this.inboxFilterId } : {};

        for (const stage of STAGES) {
          try {
            const [contactRes, convRes] = await Promise.all([
              this.api().contacts.listByLabel(stageLabel(stage), 1),
              this.api().conversations.listByLabel(stageLabel(stage), 1, convExtraFilter)
            ]);

            extractList(contactRes).forEach(contact => {
              const idStr = String(contact.id);
              if (this.ignoredContacts.has(idStr)) return;
              const attrs = contact.custom_attributes || {};
              const tags = (contact.labels || []).filter(l => !isStage(l)).join(', ');
              const phones = extractPhonesFromContact(contact);
              cardsByContact.set(idStr, {
                stage, contactId: idStr, conversationId: null, _inboxId: null,
                cliente: contact.name || contact.identifier || 'Sem nome',
                empresa: attrs.empresa || '', valor: Number(attrs.valor || 0),
                descricao: attrs.descricao || '', tags,
                phone: phones[0] || ''
              });
            });

            extractList(convRes).forEach(conv => {
              const convIdStr = String(conv.id);
              if (this.ignoredConversations.has(convIdStr)) return;
              const contact = conv.meta?.sender || conv.contact || conv.meta?.contact || {};
              const contactId = contact?.id;
              if (contactId != null && this.ignoredContacts.has(String(contactId))) return;
              const attrs = contact?.custom_attributes || {};
              const tags = (conv.labels || []).filter(l => !isStage(l)).join(', ');
              const contactPhones = extractPhonesFromContact(contact || {});
              conversationCards.push({
                stage,
                contactId: contactId != null ? String(contactId) : null,
                conversationId: convIdStr,
                _inboxId: conv.inbox_id || conv.inboxId || null,
                cliente: contact?.name || contact?.identifier || conv.meta?.sender?.name || `Conversa ${conv.display_id ?? conv.id}`,
                empresa: attrs.empresa || '', valor: Number(attrs.valor || 0),
                descricao: attrs.descricao || conv.meta?.sender?.description || '', tags,
                phone: contactPhones[0] || ''
              });
            });
          } catch (err) { console.warn('Falha ao sincronizar etapa', stage, err); }
        }

        if (CONFIG.includeUnlabeledInLeads) {
          const pages = Math.max(1, Number(CONFIG.unlabeledPages) || 1);
          for (let p = 1; p <= pages; p++) {
            try {
              const res = await this.api().contacts.list({ page: p });
              const list = extractList(res);
              list.forEach(contact => {
                const idStr = String(contact.id);
                if (this.ignoredContacts.has(idStr)) return;
                const labels = contact.labels || [];
                const hasStage = labels.some(l => isStage(l)); if (hasStage) return;
                if (cardsByContact.has(idStr)) return;
                const attrs = contact.custom_attributes || {};
                const tags = labels.filter(l => !isStage(l)).join(', ');
                const stageFromAttr = (attrs.stage && STAGES.includes(String(attrs.stage))) ? String(attrs.stage) : 'leads';
                const phones = extractPhonesFromContact(contact);
                cardsByContact.set(idStr, {
                  stage: stageFromAttr, contactId: idStr, conversationId: null, _inboxId: null,
                  cliente: contact.name || contact.identifier || 'Sem nome',
                  empresa: attrs.empresa || '', valor: Number(attrs.valor || 0),
                  descricao: attrs.descricao || '', tags,
                  phone: phones[0] || ''
                });
              });
            } catch (err) { console.warn('Falha ao carregar contatos sem etapa (página', p, '):', err); }
          }
        }

        conversationCards.forEach(card => {
          if (card.contactId && cardsByContact.has(card.contactId)) {
            const base = cardsByContact.get(card.contactId);
            base.conversationId = card.conversationId || base.conversationId;
            base.stage = card.stage;
            base.tags = card.tags || base.tags;
            base.descricao = card.descricao || base.descricao;
            base._inboxId = card._inboxId || base._inboxId;
            base.phone = base.phone || card.phone || '';
          } else {
            if (this.ignoredConversations.has(String(card.conversationId))) return;
            cardsByContact.set(`conv-${card.conversationId ?? card.cliente}`, card);
          }
        });

        const passesInboxFilter = (c) => {
          if (!this.inboxFilterId) return true;
          if (c._inboxId) return Number(c._inboxId) === Number(this.inboxFilterId);
          return false;
        };

        Array.from(cardsByContact.values()).forEach(card => {
          if (!passesInboxFilter(card)) return;
          const column = fresh[card.stage];
          if (!column) return;
          column.cards.push({
            id: card.contactId || card.conversationId || card.cliente,
            contactId: card.contactId, conversationId: card.conversationId, _inboxId: card._inboxId || null,
            cliente: card.cliente, empresa: card.empresa, valor: Number(card.valor || 0) || 0, descricao: card.descricao || '', tags: card.tags || '', stage: card.stage,
            phone: card.phone || ''
          });
        });

        this.data = fresh;
        this.saveLocal();
        this.render();
      },

      async autoSyncTick() {
        if (this.isAutoSyncRunning) return;
        this.isAutoSyncRunning = true;
        try {
          // varredura local para marcar enviados
          this.sweepSentStatuses();
          await this.syncFromAPI();
        } catch (err) {
          console.warn('Auto sync falhou', err);
        } finally { this.isAutoSyncRunning = false; }
      },
      startAutoSync() { this.stopAutoSync(); if (!Number.isFinite(this.autoSyncMs) || this.autoSyncMs <= 0) return; this.autoSyncHandle = setInterval(() => this.autoSyncTick(), this.autoSyncMs); },
      stopAutoSync() { if (this.autoSyncHandle) { clearInterval(this.autoSyncHandle); this.autoSyncHandle = null; } this.isAutoSyncRunning = false; },

      // ===== Render =====
      render() {
        // varre e marca enviados antes de desenhar
        this.sweepSentStatuses();

        const board = $('#crm-board', panel);
        if (!board) return;
        board.innerHTML = '';

        Object.values(this.data).forEach(column => {
          const col = document.createElement('div');
          col.className = 'crm-column';
          col.innerHTML = `
            <div class="crm-column-header"><span>${column.title}</span><span>${(column.cards||[]).length}</span></div>
            <div class="crm-cards" id="cards-${column.id}" data-column-id="${column.id}"></div>
          `;
          board.appendChild(col);

          const container = $(`#cards-${column.id}`, panel);
          (column.cards || []).forEach(card => {
            card.stage = column.id;
            const el = document.createElement('div');
            el.className = 'crm-card'; el.setAttribute('draggable', 'true'); el.dataset.cardId = card.id;

            const hasFuture = this.getActiveSchedules(card).length > 0;
            const badge = hasFuture ? `<span class="crm-card-badge" title="Possui mensagens agendadas futuras">⏰ Agendado</span>` : '';

            el.innerHTML = `
              <div class="crm-card-top" style="display:flex;align-items:center;justify-content:space-between;gap:.5rem;">
                <div class="crm-card-name">${card.cliente || 'Sem nome'}</div>
                ${badge}
              </div>
              <div class="crm-card-value">R$ ${Number(card.valor || 0).toLocaleString('pt-BR')}</div>
              ${card.empresa ? `<div class="crm-card-company">${card.empresa}</div>` : ''}
              ${card.descricao ? `<div class="crm-card-desc">${card.descricao}</div>` : ''}
              ${card.tags ? `<div class="crm-card-tags">${String(card.tags).split(',').map(tag => `<span class="crm-card-tag">${tag.trim()}</span>`).join('')}</div>` : ''}

              <div class="crm-card-actions">
                <button class="crm-card-open" type="button">Conversa</button>
                <button class="crm-btn" data-action="schedule" type="button" title="Agendar mensagem">Agendar mensagem</button>
              </div>
            `;

            on(el.querySelector('.crm-card-open'), 'click', async evt => { evt.stopPropagation(); await this.openConversation(card, column.id); });
            on(el.querySelector('.crm-card-send-to-leads'), 'click', async (evt) => {
              evt.stopPropagation();
              await this.moveCard(column.id, 'leads', card.id, 0);
              const cid = Number(card.contactId);
              const conv = Number(card.conversationId);
              if (Number.isFinite(cid)) await this.setContactStageLabel(cid, 'leads');
              if (Number.isFinite(conv)) await this.setConversationStageLabel(conv, 'leads');
              alert('Movido para Leads.');
            });
            on(el.querySelector('[data-action="schedule"]'), 'click', (evt) => { evt.stopPropagation(); this.showScheduleModal(card); });
            on(el.querySelector('.crm-card-hide'), 'click', (evt) => {
              evt.stopPropagation();
              const msg = 'Isso só oculta localmente (não apaga no Chatwoot). Confirmar?';
              if (confirm(msg)) this.ignoreCard(card);
            });

            on(el, 'click', () => { if (!this.isDragging) this.showDetail(card, column.id); });

            on(el, 'dragstart', e => { this.isDragging = true; this.drag = { cardId: card.id, from: column.id }; e.dataTransfer.setData('text/plain', card.id); el.classList.add('dragging'); });
            on(el, 'dragend', () => { el.classList.remove('dragging'); setTimeout(() => { this.isDragging = false; }, 40); });
            container.appendChild(el);
          });

          on(container, 'dragover', e => { e.preventDefault(); container.classList.add('drop-target'); }, { passive: false });
          on(container, 'dragleave', () => container.classList.remove('drop-target'));
          on(container, 'drop', async e => {
            e.preventDefault();
            container.classList.remove('drop-target');
            const to = container.dataset.columnId;
            const cardId = e.dataTransfer.getData('text/plain');
            const toIndex = this.getDropIndex(container, e.clientY);
            await this.moveCard(this.drag.from, to, cardId, toIndex);
          });
        });

        on(board, 'wheel', (e) => {
          const el = board; const maxScroll = el.scrollWidth - el.clientWidth;
          if (maxScroll > 0) { el.scrollLeft += (e.shiftKey ? 2.0 : 1.0) * e.deltaY; e.preventDefault(); }
        }, { passive: false });

        this.updateStats();
      },

      getStageKPI(slug) {
        return (this.stageMeta?.[slug]?.kpi) || (['ganho','perdido'].includes(slug) ? slug : (slug === 'negociacao' ? 'negociacao' : 'pipeline'));
      },

      updateStats() {
        const allCols = Object.values(this.data || {});
        const allCards = allCols.flatMap(col => col.cards || []);
        const soma = (cards) => cards.reduce((s, c) => s + (Number(c.valor) || 0), 0);

        const fmtMoney = (v) => {
          try { return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL', maximumFractionDigits: 0 }).format(v); }
          catch { return 'R$ ' + Math.round(v).toLocaleString('pt-BR'); }
        };

        const byKPI = {};
        allCols.forEach(col => {
          const kpi = this.getStageKPI(col.id);
          if (!byKPI[kpi]) byKPI[kpi] = [];
          byKPI[kpi].push(...(col.cards||[]));
        });

        const totalCards = allCards.length;
        const valorPipeline = soma([...(byKPI.pipeline || []), ...(byKPI.negociacao || [])]);
        const valorGanho = soma(byKPI.ganho || []);
        const valorNegociacao = soma(byKPI.negociacao || []);
        const ganhoCount = (byKPI.ganho || []).length;
        const conversao = totalCards ? ((ganhoCount / totalCards) * 100).toFixed(1) : '0.0';

        const setText = (id, value) => { const el = document.querySelector(`#${id}`); if (el) el.textContent = value; };
        setText('stat-total', totalCards);
        setText('stat-valor', fmtMoney(valorPipeline));
        setText('stat-ganho', fmtMoney(valorGanho));
        setText('stat-negociacao', fmtMoney(valorNegociacao));
        setText('stat-conversao', `${conversao}%`);
      },

      getDropIndex(container, y) {
        const cards = Array.from(container.querySelectorAll('.crm-card:not(.dragging)'));
        for (let i = 0; i < cards.length; i++) {
          const rect = cards[i].getBoundingClientRect();
          const mid = rect.top + rect.height / 2;
          if (y < mid) return i;
        }
        return cards.length;
      },

      async moveCard(from, to, cardId, toIndex) {
        this.updateAccountIdFromLocation(false);
        if (!from || !to || !cardId) return;

        const fromCards = this.data[from]?.cards || [];
        const idx = fromCards.findIndex(card => String(card.id) === String(cardId));

        if (idx === -1) return;

        const [card] = fromCards.splice(idx, 1);
        const destCards = this.data[to]?.cards || [];
        const insertAt = Math.max(0, Math.min(destCards.length, typeof toIndex === 'number' ? toIndex : destCards.length));
        destCards.splice(insertAt, 0, card);
        card.stage = to;

        this.saveLocal();
        this.render();

        const contactId = Number(card.contactId);
        const conversationId = Number.isFinite(Number(card.conversationId)) ? Number(card.conversationId) : null;

        if (Number.isFinite(contactId)) await this.setContactStageLabel(contactId, to);
        if (Number.isFinite(conversationId)) await this.setConversationStageLabel(conversationId, to);

        this.recordMoveHistory(card, from, to);
        this.updateStats();
      },

      // ===== Abrir conversa =====
      async openConversation(card, stageHint) {
        this.updateAccountIdFromLocation();

        const contactId = Number(card.contactId);
        const stage = stageHint || card.stage || this.getStageForConversation(Number(card.conversationId)) || this.getStageForContact(contactId);

        let convId = Number(card.conversationId);
        if (!Number.isFinite(convId) || convId <= 0) convId = await this.ensureConversationId(contactId, stage);

        if (!Number.isFinite(convId) || convId <= 0) {
          alert('Não foi possível localizar a conversa para este contato. Verifique permissões do token e se o contato possui conversas.');
          return;
        }

        if (!Number.isFinite(Number(card.conversationId))) { card.conversationId = String(convId); this.saveLocal(); }

        await this.setContactStageLabel(contactId, stage);
        await this.setConversationStageLabel(convId, stage);

        const base = CONFIG.baseUrl.replace(/\/+$/, '');
        const url = `${base}/app/accounts/${this.accountId}/conversations/${convId}`;
        const win = window.open(url, '_blank', 'noopener'); if (!win) location.href = url;
      },

      // ===== Modal de agendamento (SEM URL) =====
      async showScheduleModal(card) {
        if (!CONFIG.schedulerWebhookUrl) {
          alert('Defina CONFIG.schedulerWebhookUrl com a URL do seu Webhook (Apps Script ou n8n).');
          return;
        }

        let phone = card.phone || '';
        let email = '';
        try {
          const c = await this.api().contacts.get(Number(card.contactId));
          const phs = extractPhonesFromContact(c);
          phone = phone || phs[0] || '';
          email = c?.email || '';
        } catch {}
        phone = normalizePhone(phone, '+55'); // normaliza

        const isoLocal = new Date(Date.now() + 5*60*1000).toISOString().slice(0,16); // +5min

        const modal = document.createElement('div');
        modal.className = 'crm-modal';
        modal.innerHTML = `
          <div class="crm-modal-content">
            <div class="crm-modal-header">
              <div class="crm-modal-title">Agendar mensagem</div>
              <button class="crm-modal-close" type="button" aria-label="Fechar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 6 6 18"></path>
                  <path d="M6 6l12 12"></path>
                </svg>
              </button>
            </div>
            <div class="crm-modal-body">
              <div class="crm-form-grid">
                <div class="crm-form-group">
                  <label class="crm-form-label">Telefone (WhatsApp)</label>
                  <input class="crm-form-input" id="sched-phone" placeholder="+55..." value="${phone || ''}">
                </div>
                <div class="crm-form-group">
                  <label class="crm-form-label">Anexo (opcional)</label>
                  <input class="crm-form-input" id="sched-file" type="file" accept="image/*,video/*,application/pdf,application/zip,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document">
                </div>
                <div class="crm-form-group">
                  <label class="crm-form-label">Data e hora</label>
                  <input class="crm-form-input" id="sched-datetime" type="datetime-local" value="${isoLocal}">
                </div>
                <div></div>
              </div>
              <div class="crm-form-group">
                <label class="crm-form-label">Mensagem</label>
                <textarea class="crm-form-input" id="sched-text" rows="4" placeholder="Escreva a mensagem..."></textarea>
              </div>
              <div class="crm-form-actions">
                <button class="crm-btn-primary" id="sched-save">Agendar</button>
                <button class="crm-btn-secondary" id="sched-cancel">Cancelar</button>
              </div>
              <div style="color:var(--crm-text-secondary);font-size:.8rem;margin-top:.6rem">
                Obs.: fora da janela de 24h do WhatsApp, o backend deve usar template/HSM via Evolution API.
              </div>
            </div>
          </div>`;
        panel.appendChild(modal);

        const close = () => modal.remove();
        modal.querySelector('.crm-modal-close').onclick = close;
        modal.querySelector('#sched-cancel').onclick = close;

        const elPhone = modal.querySelector('#sched-phone');
        const elDT    = modal.querySelector('#sched-datetime');
        const elText  = modal.querySelector('#sched-text');
        const elFile  = modal.querySelector('#sched-file');

        // Quick-picks de múltiplos números (se existirem)
        (async () => {
          try {
            const c = await this.api().contacts.get(Number(card.contactId));
            const list = extractPhonesFromContact(c);
            const unique = list.filter(Boolean);
            if (unique.length > 1) {
              const wrap = document.createElement('div');
              wrap.style.cssText = 'margin:.5rem 0; display:flex; flex-wrap:wrap; gap:.35rem;';
              unique.forEach(p => {
                const b = document.createElement('button');
                b.className = 'crm-btn';
                b.type = 'button';
                b.textContent = p;
                b.onclick = () => { elPhone.value = p; };
                wrap.appendChild(b);
              });
              elPhone.closest('.crm-form-group').appendChild(wrap);
            }
          } catch {}
        })();

        on(modal.querySelector('#sched-save'), 'click', async () => {
          const phone = normalizePhone((elPhone.value || '').trim(), '+55');
          const text = (elText.value || '').trim();
          const whenLocal = elDT.value; // 'YYYY-MM-DDTHH:mm'
          const timezone = CONFIG.fixedTimezone || 'America/Sao_Paulo';

          if (!phone) { alert('Informe o telefone.'); return; }
          if (!text && !(elFile && elFile.files && elFile.files[0])) { alert('Informe a mensagem ou um anexo.'); return; }
          if (!whenLocal) { alert('Informe a data/hora.'); return; }

          const when = new Date(whenLocal);
          if (!Number.isFinite(when.getTime())) { alert('Data/hora inválida.'); return; }

          // >>> ALTERAÇÃO: gerar e usar o MESMO scheduleId (também enviado ao backend)
          const scheduleId = [
            'cw',
            String(this.accountId || '0'),
            String(card.conversationId || '0'),
            Date.now().toString(36),
            Math.random().toString(36).slice(2,8)
          ].join('-');

          const payload = {
            source: 'kanban-crm',
            accountId: this.accountId,
            conversationId: Number(card.conversationId) || null,
            contactId: Number(card.contactId) || null,
            contact: { name: card.cliente || '', phone, email: '' },
            message: { text }, // sem URL
            sendAtIso: when.toISOString(),
            timezone,
            provider: 'evolution',
            crm: {
              stage: card.stage || null,
              empresa: card.empresa || null,
              valor: Number(card.valor || 0) || 0,
              tags: (card.tags || '').split(',').map(s => s.trim()).filter(Boolean)
            },
            meta: { userAgent: navigator.userAgent, scheduledAtClient: new Date().toISOString() },
            scheduleId,              // <— envia o mesmo ID
            clientScheduleId: scheduleId
          };

          try {
            let res;
            if (elFile && elFile.files && elFile.files[0]) {
              const fd = new FormData();
              fd.append('file', elFile.files[0]);
              fd.append('payload', JSON.stringify(payload));
              res = await fetch(CONFIG.schedulerWebhookUrl, { method: 'POST', body: fd });
            } else {
              res = await fetch(CONFIG.schedulerWebhookUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
              });
            }

            if (!res || (res.type !== 'opaque' && !res.ok)) {
              const txt = res ? await res.text().catch(()=> '') : '';
              throw new Error('Falha no webhook: ' + (res?.status || '') + ' ' + txt);
            }

            // grava no storage compartilhado (por conversa) usando o MESMO ID gerado
            await this.upsertSchedule(card, {
              id: scheduleId,
              sendAtIso: payload.sendAtIso,
              text: payload.message.text,
              status: 'scheduled',
              createdAt: new Date().toISOString()
            });

            alert('Agendamento enviado para a fila com sucesso!');
            this.render(); // atualiza badges
            close();
          } catch (e) {
            console.error(e);
            alert('Erro ao enviar para o webhook.\n' + (e.message || e));
          }
        });
      },

