  // ====== ESCOLHE ABRIDOR ======
  function openLightweightScheduler(card){
    if (window.HTMLDialogElement && typeof document.createElement('dialog').showModal === 'function') {
      openSchedulerDialog(card);
    } else {
      openLightweightSchedulerFallback(card);
    }
  }

  // ====== CARD DA CONVERSA ATUAL ======
  async function buildCardForCurrentConversation(){
    const accountId = detectAccountId();
    const conversationId = detectConversationId();
    if (!Number.isFinite(accountId) || !Number.isFinite(conversationId)) { alert('Não encontrei a conversa atual.'); return null; }
    const api = makeAPI(accountId);
    let conv, contact, contactId=null, inboxId=null, phone=null;
    try {
      conv = await api.conversations.get(conversationId);
      const c = conv?.meta?.sender || conv?.contact || conv?.meta?.contact || {};
      contactId = Number(c?.id);
      inboxId = conv?.inbox_id || conv?.inboxId || null;
      if (Number.isFinite(contactId)) { contact = await api.contacts.get(contactId); }
      phone = pickBestPhone(contact, conv);
    } catch (e) { console.warn('Falha ao obter conversa/contato', e); }
    if (!Number.isFinite(contactId)) { alert('Conversa sem contato associado.'); return null; }

    const name = contact?.name || contact?.identifier || `Contato ${contactId}`;
    const attrs = contact?.custom_attributes || {};
    const email = contact?.email || '';
    const labels = contact?.labels || [];
    const tags = (labels || []).filter(l => !/^crm[:\-]/.test(l)).join(', ');
    const stage = (attrs.stage && typeof attrs.stage === 'string') ? attrs.stage : 'leads';

    return {
      id: String(contactId),
      contactId: String(contactId),
      conversationId: String(conversationId),
      _inboxId: inboxId || null,
      accountId,
      cliente: name,
      empresa: attrs.empresa || '',
      valor: Number(attrs.valor || 0) || 0,
      descricao: attrs.descricao || '',
      tags,
      stage,
      email,
      phone
    };
  }

  // ====== ABRIR (com correção PRINCIPAL) ======
  async function openScheduleForCurrentConversation(){
    const card = await buildCardForCurrentConversation();
    if (!card) return;

    const crmPanel = document.getElementById('crm-panel');
    const crmVisible = !!(crmPanel && getComputedStyle(crmPanel).display !== 'none');

    // >>> CORREÇÃO: só usa o modal do Kanban SE o painel estiver visível
    if (crmVisible && window.CRM && typeof window.CRM.showScheduleModal === 'function') {
      window.CRM.showScheduleModal(card);
    } else {
      openLightweightScheduler(card); // nosso modal (dialog top-layer / overlay)
    }
  }

  // ====== CANCELAR ======
  async function cancelSchedule(scheduleId, card){
    const payload = { action: 'cancel', scheduleId, accountId: card.accountId, conversationId: Number(card.conversationId)||null, contactId: Number(card.contactId)||null };
    const res = await fetch(CONFIG.schedulerWebhookUrl, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload) });
    if (!res || (res.type!=='opaque' && !res.ok)) {
      const txt = res ? await res.text().catch(()=> '') : '';
      throw new Error('Falha ao cancelar: '+(res?.status||'')+' '+txt);
    }
    markStatus(card.accountId, card.conversationId, scheduleId, 'canceled');
  }

  // ====== UI: BOTÕES ======
  function findPrivateNoteButton(){
    let el = $('[data-testid*="private" i], [data-testid*="privada" i]');
    if (el) return el;
    el = $$('[aria-label]').find(x => /nota privada|mensagem privada|private/i.test(x.getAttribute('aria-label')||''));
    if (el) return el;
    const btns = $$('button, [role="button"]');
    return btns.find(b => { const t = nrm(b.textContent); return t.includes('nota privada') || t.includes('mensagem privada') || t.includes('private note'); });
  }

  function createBlueTinyButton(){
    const btn = document.createElement('button');
    btn.id = 'btn-agendar-ao-lado-da-privada';
    btn.type = 'button';
    btn.title = 'Agendar mensagem';
    btn.textContent = 'Agendar Mensagens';
    btn.style.cssText = [
      'margin-left:-10px','margin-top:12px','display:inline-flex','align-items:center','gap:6px',
      `height:${UI.btnH}px`,`padding:${UI.padY}px ${UI.padX}px`,'border-radius:8px','border:0',
      'background:linear-gradient(135deg,#3b82f6,#2563eb)','color:#fff','font-weight:800','font-size:12px','line-height:1',
      'cursor:pointer','box-shadow:0 6px 14px rgba(37,99,235,.30)'
    ].join(';');
    btn.onmouseenter = () => btn.style.filter = 'brightness(1.05)';
    btn.onmouseleave = () => btn.style.filter = '';
    on(btn, 'click', openScheduleForCurrentConversation);
    return btn;
  }

  function createBellButton(){
    const btn = document.createElement('button');
    btn.id = 'btn-bell-agendados';
    btn.type = 'button';
    btn.title = 'Mensagens agendadas';
    btn.innerHTML = '🔔';
    btn.style.cssText = [
      'margin-left:-60px','margin-top:12px','display:inline-flex','align-items:center','justify-content:center',
      `height:${UI.btnH}px`,`min-width:${UI.btnH}px`,'border-radius:999px','border:0',
      'background:linear-gradient(135deg,#3b82f6,#2563eb)','color:#fff','font-weight:800','font-size:14px','line-height:1',
      'cursor:pointer','box-shadow:0 6px 14px rgba(37,99,235,.30)','position:relative','padding:0 8px','gap:6px'
    ].join(';');
    const span = document.createElement('span');
    span.id = 'bell-count';
    span.style.cssText = 'background:#ef4444;color:#fff;border-radius:999px;padding:2px 6px;font-size:11px;font-weight:900;display:none';
    btn.appendChild(span);
    return btn;
  }

  function updateBellCount(bellBtn, count){
    const s = bellBtn.querySelector('#bell-count');
    if (!s) return;
    if (count > 0) { s.textContent = String(count); s.style.display='inline-block'; }
    else { s.textContent=''; s.style.display='none'; }
  }

  function showBellMenu(anchorBtn, card){
    const old = $('#menu-agendados-pop'); if (old) old.remove();
    const menu = document.createElement('div');
    menu.id = 'menu-agendados-pop';
    menu.style.cssText = 'position:absolute;z-index:2147483003;background:#0f172a;color:#fff;border:1px solid #334155;border-radius:10px;box-shadow:0 10px 26px rgba(0,0,0,.35);min-width:260px;max-width:360px;max-height:300px;overflow:auto;padding:8px';
    const rect = anchorBtn.getBoundingClientRect();
    menu.style.top = (rect.bottom + window.scrollY + 6) + 'px';
    menu.style.left = (rect.left + window.scrollX) + 'px';

    const items = getList(card.accountId, card.conversationId)
      .filter(s => (s.status||'scheduled')==='scheduled' && isFuture(s.sendAtIso));

    if (!items.length) {
      menu.innerHTML = '<div style="padding:8px 10px;color:#94a3b8;font-size:13px">Sem agendamentos futuros.</div>';
    } else {
      menu.innerHTML = items.map(it => {
        const dt = new Date(it.sendAtIso);
        const when = Number.isFinite(dt.getTime()) ? dt.toLocaleString() : it.sendAtIso;
        const txt = (it.text||'').slice(0,120);
        return `
          <div style="border:1px solid #334155;border-radius:8px;padding:8px 10px;margin:6px 0;background:#0b1220">
            <div style="font-size:12px;color:#94a3b8;margin-bottom:4px">${when}</div>
            <div style="font-size:13px;white-space:pre-wrap">${txt}</div>
            <div style="display:flex;gap:6px;margin-top:8px">
              <button data-action="cancel" data-id="${it.id}" style="background:transparent;border:1px solid #ef4444;color:#ef4444;border-radius:8px;padding:6px 10px;font-weight:800;cursor:pointer">Cancelar</button>
            </div>
          </div>
        `;
      }).join('');
    }

    document.body.appendChild(menu);

    const outside = (ev) => {
      if (!menu.contains(ev.target) && ev.target !== anchorBtn) {
        menu.remove(); document.removeEventListener('mousedown', outside);
      }
    };
    document.addEventListener('mousedown', outside);

    on(menu, 'click', async (e) => {
      const btn = e.target.closest('button[data-action="cancel"]');
      if (!btn) return;
      const id = btn.getAttribute('data-id');
      if (!confirm('Cancelar este agendamento?')) return;
      try {
        await cancelSchedule(id, card);
        menu.remove();
        refreshBellForCurrentRow();
        alert('Agendamento cancelado.');
      } catch (err) { alert(err.message || 'Erro ao cancelar.'); }
    });
  }

  async function ensureBellForCurrentConversation(afterThisEl){
    const card = await buildCardForCurrentConversation().catch(()=>null);
    if (!card) return;
    const active = getList(card.accountId, card.conversationId).filter(s => (s.status||'scheduled')==='scheduled' && isFuture(s.sendAtIso));
    let bell = $('#btn-bell-agendados');
    if (!active.length) { if (bell) bell.remove(); return; }
    if (!bell) {
      bell = createBellButton();
      afterThisEl.insertAdjacentElement('afterend', bell);
      on(bell, 'click', () => showBellMenu(bell, card));
    }
    updateBellCount(bell, active.length);
  }

  async function refreshBellForCurrentRow(){
    const agendarBtn = $('#btn-agendar-ao-lado-da-privada');
    if (!agendarBtn) return;
    await ensureBellForCurrentConversation(agendarBtn);
  }

  function findPrivateNoteButton(){
    let el = $('[data-testid*="private" i], [data-testid*="privada" i]');
    if (el) return el;
    el = $$('[aria-label]').find(x => /nota privada|mensagem privada|private/i.test(x.getAttribute('aria-label')||''));
    if (el) return el;
    const btns = $$('button, [role="button"]');
    return btns.find(b => {
      const t = nrm(b.textContent);
      return t.includes('nota privada') || t.includes('mensagem privada') || t.includes('private note');
    });
  }

  function injectButtons(){
    if (!/\/app\/accounts\/\d+\/conversations\/\d+/.test(location.pathname)) {
      const old1 = $('#btn-agendar-ao-lado-da-privada'); if (old1) old1.remove();
      const old2 = $('#btn-bell-agendados'); if (old2) old2.remove();
      const old3 = $('#menu-agendados-pop'); if (old3) old3.remove();
      return false;
    }
    const ref = findPrivateNoteButton();
    if (!ref) return false;

    const container = ref.parentElement;
    if (container) {
      const gap = parseFloat(getComputedStyle(container).gap || '0');
      if (gap > 10) container.style.gap = '6px';
    }

    let bAg = $('#btn-agendar-ao-lado-da-privada');
    if (!bAg) {
      bAg = createBlueTinyButton();
      if (ref.parentElement) ref.parentElement.insertBefore(bAg, ref.nextSibling);
      else ref.insertAdjacentElement('afterend', bAg);
    }

    ensureBellForCurrentConversation(bAg);
    return true;
  }

  function mount(){ injectButtons(); }

  mount();
  let moTicking = false;
  const mo = new MutationObserver(() => { if (moTicking) return; moTicking = true; setTimeout(() => { moTicking = false; mount(); }, 180); });
  mo.observe(document.body, { childList:true, subtree:true });
  window.addEventListener('popstate', () => setTimeout(mount, 50));
  window.addEventListener('hashchange', () => setTimeout(mount, 50));
  window.addEventListener('storage', (e) => { if (e.key === 'cw:schedules:v2') setTimeout(() => refreshBellForCurrentRow(), 80); });
})();
</script>







<script>
(function () {
  // ===== Helpers base =====
  const $ = (sel, root = document) => { try { return root.querySelector(sel); } catch { return null; } };
  const $$ = (sel, root = document) => { try { return Array.from(root.querySelectorAll(sel)); } catch { return []; } };
  const on = (el, ev, fn, opts) => {
    if (!el) return;
    const def = /^(touchstart|touchmove|wheel)$/.test(ev) ? { passive: true } : undefined;
    el.addEventListener(ev, fn, opts ?? def);
  };

  // ==== Helpers de telefone ====
  function normalizePhone(raw, defaultCountry = '+55') {
    if (!raw) return '';
    let s = String(raw).replace(/[^\d+]/g, '');
    if (s.startsWith('00')) s = '+' + s.slice(2);
    if (!s.startsWith('+')) {
      s = s.replace(/^0+/, '');
      if (s.startsWith('55')) s = '+' + s;
      else s = defaultCountry + s;
    }
    return s;
  }
  function extractPhonesFromContact(c) {
    const out = new Set();
    const tryPush = v => { const n = normalizePhone(v||''); if (n) out.add(n); };
    tryPush(c?.phone_number);
    tryPush(c?.additional_attributes?.phone_number);
    tryPush(c?.additional_attributes?.whatsapp);
    const ca = c?.custom_attributes || {};
    ['telefone','celular','whatsapp','phone','mobile'].forEach(k => tryPush(ca[k]));
    return [...out];
  }

  // ===== Tema =====
  const isDarkTheme = () =>
    document.documentElement.classList.contains('dark') ||
    (window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches);
  const getThemeColor = () => (isDarkTheme() ? 'rgb(15, 23, 42)' : '#ffffff');
  const updatePanelTheme = (panel) => { if (!panel) return; panel.style.background = getThemeColor(); panel.dataset.theme = isDarkTheme() ? 'dark' : 'light'; };

  // ===== Config =====
  const CONFIG = {
    baseUrl: location.origin,
    token: 'MZiA3XsZF4R3MnZdYCadEJJg', // <<< substitua
    inboxByAccount: {},
    includeUnlabeledInLeads: true,
    unlabeledPages: 1,
    allowAutoCreateConversation: true,
    schedulerWebhookUrl: 'https://n8n.g3growth.com.br/webhook/chatwoot', // envio e cancelamento no mesmo endpoint
    fixedTimezone: 'America/Sao_Paulo'
  };

  // ===== Constantes CRM =====
  const STAGES = ['leads', 'contato', 'proposta', 'negociacao', 'ganho', 'perdido'];
  const stageLabel = s => `crm-${s}`;
  const stageLabelLegacy = s => `crm:${s}`;
  const ALL_STAGE_LABELS = STAGES.flatMap(s => [stageLabel(s), stageLabelLegacy(s)]);
  const isStage = label => typeof label === 'string' && /^crm[:\-]/.test(label);

  const detectAccountId = () => { const m = (location.pathname || '').match(/\/accounts\/(\d+)/); return m ? Number(m[1]) : NaN; };
  const keyFor = (accountId, name) => `kanban-crm:${accountId}:${name}`;
  const extractList = payload => {
    if (Array.isArray(payload)) return payload;
    if (Array.isArray(payload?.data)) return payload.data;
    if (Array.isArray(payload?.payload)) return payload.payload;
    if (Array.isArray(payload?.data?.payload)) return payload.data.payload;
    if (Array.isArray(payload?.data?.conversations)) return payload.data.conversations;
    if (Array.isArray(payload?.conversations)) return payload.conversations;
    return [];
  };
  const resolveAccountId = () => {
    const detected = detectAccountId();
    if (Number.isFinite(detected) && detected > 0) {
      localStorage.setItem('kanban-crm:account', String(detected));
      localStorage.removeItem('kanban-crm(JFrame account>dialogueaccount)');
      return detected;
    }
    const stored = Number(localStorage.getItem('kanban-crm:account'));
    if (Number.isFinite(stored) && stored > 0) return stored;
    const legacy = Number(localStorage.getItem('kanban-crm(JFrame account>dialogueaccount)'));
    if (Number.isFinite(legacy) && legacy > 0) {
      localStorage.setItem('kanban-crm:account', String(legacy));
      localStorage.removeItem('kanban-crm(JFrame account>dialogueaccount)');
      return legacy;
    }
    return 1;
  };

  // ===== Persistência de meta/KPI =====
  const stageMetaKey = (accountId) => keyFor(accountId, 'stageMeta');
  function loadStageMeta(accountId){ try { return JSON.parse(localStorage.getItem(stageMetaKey(accountId)) || '{}'); } catch { return {}; } }
  function saveStageMeta(accountId, meta){ localStorage.setItem(stageMetaKey(accountId), JSON.stringify(meta || {})); }

  // ===== API =====
  function makeAPI(accountId) {
    const base = CONFIG.baseUrl.replace(/\/+$/, '') + '/api/v1';
    const headers = {
      'Content-Type': 'application/json',
      'Accept': 'application/json',
      'api_access_token': CONFIG.token,
      'Authorization': `Bearer ${CONFIG.token}`
    };
    async function request(path, opts = {}) {
      const url = `${base}/accounts/${accountId}${path}`;
      const init = { credentials: 'include', headers, ...opts };
      let res = await fetch(url, init);
      if ((res.status === 401 || res.status === 403) && CONFIG.token) {
        const sep = url.includes('?') ? '&' : '?';
        res = await fetch(`${url}${sep}api_access_token=${encodeURIComponent(CONFIG.token)}`, init);
      }
      const ct = res.headers.get('content-type') || '';
      if (!res.ok) {
        const err = new Error(`${opts.method || 'GET'} ${path} -> ${res.status}`);
        err.status = res.status;
        try { err.body = await res.text(); } catch { err.body = ''; }
        throw err;
      }
      return ct.includes('application/json') ? res.json() : null;
    }
    return {
      labels: {
        list: () => request('/labels'),
        create: (title, color = '#3b82f6') => request('/labels', { method: 'POST', body: JSON.stringify({ title, color }) }),
      },
      inboxes: { list: () => request('/inboxes') },
      meta: { conversations: () => request('/conversations/meta') },
      contacts: {
        list: (params = {}) => request('/contacts?' + new URLSearchParams(params).toString()),
        get: (id) => request(`/contacts/${id}`),
        listByLabel: (label, page = 1) => request('/contacts?' + new URLSearchParams({ 'labels[]': label, page }).toString()),
        create: payload => request('/contacts', { method: 'POST', body: JSON.stringify(payload) } ),
        update: (id, payload) => request(`/contacts/${id}`, { method: 'PATCH', body: JSON.stringify(payload) }),
        addOrReplaceLabels: (id, labels) => request(`/contacts/${id}/labels`, { method: 'POST', body: JSON.stringify({ labels }) }),
        notes: (id, content) => request(`/contacts/${id}/notes`, { method: 'POST', body: JSON.stringify({ content }) }),
        listNotes: id => request(`/contacts/${id}/notes`),
        conversations: id => request(`/contacts/${id}/conversations`)
      },
      conversations: {
        get: (id) => request(`/conversations/${id}`),
        listByLabel: (label, page = 1, extra = {}) =>
          request('/conversations?' + new URLSearchParams({ 'labels[]': label, page, ...extra }).toString()),
        addOrReplaceLabels: (id, labels) => request(`/conversations/${id}/labels`, { method: 'POST', body: JSON.stringify({ labels }) }),
        addPrivateNote: (id, content) => request(`/conversations/${id}/messages`, { method: 'POST', body: JSON.stringify({ content, private: true }) }),
        create: payload => request('/conversations', { method: 'POST', body: JSON.stringify(payload) })
      }
    };
  }

  // ===== UI mount points =====
  const findSidebar = () => $('[data-testid="sidebar-primary"]') || $('aside');

  const __norm = s => (s||'').toLowerCase()
    .normalize('NFD').replace(/[\u0300-\u036f]/g,'')
