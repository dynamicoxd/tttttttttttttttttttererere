      </div>
      <div class="bd">
        <div class="row">
          <div>
            <div class="lbl">Telefone (WhatsApp)</div>
            <input id="sd-phone" type="text" placeholder="+55..." />
          </div>
          <div>
            <div class="lbl">Data e hora</div>
            <input id="sd-dt" type="datetime-local" value="${isoLocal}" />
          </div>
        </div>
        <div style="margin-top:10px">
          <div class="lbl">Mensagem</div>
          <textarea id="sd-text" rows="4" placeholder="Escreva a mensagem..."></textarea>
        </div>
        <div style="margin-top:10px">
          <div class="lbl">Anexo (opcional)</div>
          <input id="sd-file" class="file" type="file" accept="image/*,video/*,application/pdf,application/zip,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document">
        </div>
        <div class="actions">
          <button id="sd-save" class="btn-primary">Agendar Mensagens</button>
          <button id="sd-cancel" class="btn-ghost">Cancelar</button>
          <div style="color:${subtle};font-size:12px;align-self:center">Fora da janela de 24h, usar template/HSM no backend.</div>
        </div>
      </div>
    `;

    document.body.appendChild(dlg);
    const phoneInput = $('#sd-phone', dlg);
    if (card.phone) phoneInput.value = card.phone;

    try { dlg.showModal(); } catch {}
    const close = () => { try { dlg.close(); } catch {}; dlg.remove(); };

    on($('#sd-x', dlg), 'click', close);
    on($('#sd-cancel', dlg), 'click', close);

    on($('#sd-save', dlg), 'click', async () => {
      const phone = (phoneInput.value||'').trim();
      const whenLocal = $('#sd-dt', dlg).value;
      const text = ($('#sd-text', dlg).value||'').trim();
      const file = $('#sd-file', dlg).files?.[0]||null;
      if (!phone) { alert('Informe o telefone.'); return; }
      if (!text && !file) { alert('Informe a mensagem ou um anexo.'); return; }
      if (!whenLocal) { alert('Informe a data/hora.'); return; }
      const when = new Date(whenLocal);
      if (!Number.isFinite(when.getTime())) { alert('Data/hora inválida.'); return; }

      // >>> ALTERAÇÃO 1/2: gerar e usar MESMO scheduleId
      const scheduleId = [
        'cw',
        String(card.accountId || '0'),
        String(card.conversationId || '0'),
        Date.now().toString(36),
        Math.random().toString(36).slice(2,8)
      ].join('-');

      const payload = {
        source: 'conversation-scheduler-btn',
        accountId: card.accountId,
        conversationId: Number(card.conversationId) || null,
        contactId: Number(card.contactId) || null,
        contact: { name: card.cliente || '', phone, email: card.email || '' },
        message: { text },
        sendAtIso: when.toISOString(),
        timezone: CONFIG.fixedTimezone || 'America/Sao_Paulo',
        provider: 'evolution',
        crm: { stage: card.stage || null, empresa: card.empresa || null, valor: Number(card.valor||0)||0, tags: (card.tags||'').split(',').map(s=>s.trim()).filter(Boolean) },
        meta: { userAgent: navigator.userAgent, scheduledAtClient: new Date().toISOString() },
        scheduleId,               // <— envia o mesmo ID
        clientScheduleId: scheduleId
      };

      try {
        let res;
        if (file) { const fd = new FormData(); fd.append('file', file); fd.append('payload', JSON.stringify(payload)); res = await fetch(CONFIG.schedulerWebhookUrl, { method:'POST', body: fd }); }
        else { res = await fetch(CONFIG.schedulerWebhookUrl, { method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify(payload) }); }
        if (!res || (res.type!=='opaque' && !res.ok)) { const txt = res ? await res.text().catch(()=> '') : ''; throw new Error('Falha no webhook: '+(res?.status||'')+' '+txt); }
        if (res && res.type !== 'opaque') { try { await res.json(); } catch {} }

        addSchedule(card.accountId, card.conversationId, { id: scheduleId, sendAtIso: payload.sendAtIso, text: payload.message.text, status: 'scheduled', createdAt: new Date().toISOString() });
        refreshBellForCurrentRow();
        alert('Agendamento enviado com sucesso!');
        close();
      } catch (e) { alert(e?.message || 'Erro ao enviar para o webhook.'); }
    });
  }

