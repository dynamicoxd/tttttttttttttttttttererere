                <select class="crm-form-select" id="add-stage">
                  ${STAGES.map(s => `<option value="${s}" ${s==='leads'?'selected':''}>${s.charAt(0).toUpperCase()+s.slice(1)}</option>`).join('')}
                </select>
              </div>

              <div style="margin:.6rem 0; display:flex; gap:.5rem;">
                <button class="crm-btn" id="tab-contacts">Contatos</button>
                <button class="crm-btn" id="tab-conversations">Conversas</button>
              </div>

              <div id="add-results" style="max-height:50vh;overflow:auto;border:1px solid var(--crm-border);border-radius:.6rem;padding:.5rem"></div>
            </div>
          </div>`;
        panel.appendChild(modal);
        const close = () => modal.remove();
        modal.querySelector('.crm-modal-close').onclick = close;

        const input = modal.querySelector('#add-search');
        const stageSel = modal.querySelector('#add-stage');
        const results = modal.querySelector('#add-results');
        let mode = 'contacts';

        const renderList = (items, type) => {
          if (!items.length) { results.innerHTML = '<div style="color:var(--crm-text-secondary)">Nenhum resultado</div>'; return; }
          results.innerHTML = items.map(it => {
            if (type === 'contacts') {
              const name = it.name || it.identifier || `Contato ${it.id}`;
              const extra = it.email || it.phone_number || '';
              return `<div style="display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--crm-border);padding:.5rem 0">
                <div>
                  <div style="font-weight:700">${name}</div>
                  <div style="color:var(--crm-text-secondary);font-size:.85rem">#${it.id} ${extra? '— '+extra : ''}</div>
                </div>
                <button class="crm-btn" data-type="add-contact" data-id="${it.id}">Adicionar</button>
              </div>`;
            } else {
              const cid = it.id;
              const disp = it.display_id || cid;
              const contact = it.meta?.sender || it.contact || {};
              const cname = contact?.name || contact?.identifier || `Contato ${contact?.id || ''}`;
              return `<div style="display:flex;justify-content:space-between;align-items:center;border-bottom:1px solid var(--crm-border);padding:.5rem 0">
                <div>
                  <div style="font-weight:700">Conversa #${disp}</div>
                  <div style="color:var(--crm-text-secondary);font-size:.85rem">${cname || ''}</div>
                </div>
                <button class="crm-btn" data-type="add-conv" data-id="${cid}">Adicionar</button>
              </div>`;
            }
          }).join('');
        };

        const search = async (term) => {
          results.innerHTML = '<div style="color:var(--crm-text-secondary)">Buscando...</div>';
          try {
            if (mode === 'contacts') {
              let res = await this.api().contacts.list({ q: term, page: 1 });
              let list = extractList(res);
              if (!list.length) {
                res = await this.api().contacts.list({ search: term, page: 1 });
                list = extractList(res);
              }
              renderList(list, 'contacts');
            } else {
              let convs = [];
              try {
                const cres = await this.api().contacts.list({ q: term, page: 1 });
                const clist = extractList(cres).slice(0, 8);
                for (const c of clist) {
                  const r = await this.api().contacts.conversations(c.id);
                  convs.push(...extractList(r));
                }
              } catch {}
              renderList(convs.slice(0, 20), 'conversations');
            }
          } catch (e) {
            results.innerHTML = `<div style="color:#f87171">Erro na busca: ${e.body || e.message}</div>`;
          }
        };

        let t; const deb = (fn, ms=400) => (...a) => { clearTimeout(t); t=setTimeout(()=>fn(...a), ms); };
        on(input, 'input', deb(e => { const v = e.target.value.trim(); if (v) search(v); else results.innerHTML=''; }, 400));

        on(results, 'click', async (e) => {
          const btn = e.target.closest('button[data-type]');
          if (!btn) return;
          const stage = stageSel.value || 'leads';
          if (btn.dataset.type === 'add-contact') {
            const ok = await this.addCardFromContact(Number(btn.dataset.id), stage);
            if (ok) alert('Adicionado ao Kanban.');
          } else {
            const ok = await this.addCardFromConversation(Number(btn.dataset.id), stage);
            if (ok) alert('Adicionado ao Kanban.');
          }
        });

        on(modal.querySelector('#tab-contacts'), 'click', ()=>{ mode='contacts'; if (input.value.trim()) search(input.value.trim()); });
        on(modal.querySelector('#tab-conversations'), 'click', ()=>{ mode='conversations'; if (input.value.trim()) search(input.value.trim()); });
      },

      showCreateContactModal() {
        const modal = document.createElement('div');
        modal.className = 'crm-modal';
        modal.innerHTML = `
          <div class="crm-modal-content">
            <div class="crm-modal-header">
              <div class="crm-modal-title">Novo contato</div>
              <button class="crm-modal-close" type="button" aria-label="Fechar">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M18 6 6 18"></path>
                  <path d="M6 6l12 12"></path>
                </svg>
              </button>
            </div>
            <div class="crm-modal-body">
              <div class="crm-form-grid">
                <div class="crm-form-group">
                  <label class="crm-form-label">Nome</label>
                  <input class="crm-form-input" id="new-name" placeholder="Ex: Maria Silva">
                </div>
                <div class="crm-form-group">
                  <label class="crm-form-label">E-mail</label>
                  <input class="crm-form-input" id="new-email" placeholder="email@dominio.com">
                </div>
                <div class="crm-form-group">
                  <label class="crm-form-label">Telefone</label>
                  <input class="crm-form-input" id="new-phone" placeholder="+55...">
                </div>
                <div class="crm-form-group">
                  <label class="crm-form-label">Empresa</label>
                  <input class="crm-form-input" id="new-company" placeholder="Opcional">
                </div>
                <div class="crm-form-group">
                  <label class="crm-form-label">Valor (R$)</label>
                  <input type="number" class="crm-form-input" id="new-value" placeholder="0">
                </div>
                <div class="crm-form-group">
                  <label class="crm-form-label">Descrição</label>
                  <input class="crm-form-input" id="new-desc" placeholder="Opcional">
                </div>
              </div>
              <div class="crm-form-actions">
                <button class="crm-btn-primary" id="new-save">Criar e adicionar (Leads)</button>
              </div>
            </div>
          </div>`;
        panel.appendChild(modal);
        const close = () => modal.remove();
        modal.querySelector('.crm-modal-close').onclick = close;

        on(modal.querySelector('#new-save'), 'click', async () => {
          const name = modal.querySelector('#new-name').value.trim();
          const email = modal.querySelector('#new-email').value.trim();
          const phone = modal.querySelector('#new-phone').value.trim();
          const empresa = modal.querySelector('#new-company').value.trim();
          const valor = Number(modal.querySelector('#new-value').value) || 0;
          const descricao = modal.querySelector('#new-desc').value.trim();

          if (!name && !email && !phone) { alert('Informe pelo menos Nome, E-mail ou Telefone.'); return; }

          try {
            const payload = {
              name: name || undefined,
              email: email || undefined,
              phone_number: phone || undefined,
              custom_attributes: { empresa, valor, descricao }
            };
            const res = await this.api().contacts.create(payload);
            const id = res?.id || res?.payload?.id;
            if (!id) throw new Error('Contato criado, mas sem ID retornado.');
            await this.addCardFromContact(Number(id), 'leads');
            alert('Contato criado e adicionado em Leads.');
            close();
          } catch (e) {
            alert(`Falha ao criar contato: ${e.body || e.message}`);
          }
        });
      }
    };

    window.CRM = CRM;
    CRM.init();

    window.showCRM = () => {
      const p = $('#crm-panel') || panel;
      if (!p) return;
      CRM.updateAccountIdFromLocation();
      CRM.render();
      updatePanelTheme(p);
      p.style.display = 'block';
      p.scrollTop = 0;
      document.body.style.overflow = 'hidden';
      CRM.startAutoSync();
    };
    window.closeCRM = () => {
      const p = $('#crm-panel') || panel;
      if (!p) return;
      p.style.display = 'none';
      document.body.style.overflow = '';
      CRM.stopAutoSync();
    };

    return panel;
  }

  // ===== Link na sidebar =====
  const addSidebarLink = () => {
    if ($('#crm-sidebar-link')) return;
    const ul = findConversationsList(); if (!ul) return;
    const anchor = findAllConversationsItem(); if (!anchor) return;

    const li = document.createElement('li');
    li.id = 'crm-sidebar-link';
    li.style.listStyle = 'none';
   li.innerHTML=`<a href="javascript:void(0)" style="display:flex;align-items:center;gap:10px;padding:8px 12px;border-radius:8px;text-decoration:none;color:inherit;">
      <span style="display:inline-flex;width:24px;height:24px;border-radius:6px;background:linear-gradient(135deg,#3b82f6,#8b5cf6);align-items:center;justify-content:center;color:#fff;font-weight:900">K</span>
      <span style="font-weight:600;">Kanban CRM</span>
     </a>`;
    on(li.querySelector('a'), 'click', () => { if (window.showCRM) window.showCRM(); });

    ul.insertBefore(li, anchor.nextSibling);
  };

  // ===== Boot =====
  const boot = () => {
    if (_booted) return;
    _booted = true;
    createCRMPanel();
    addSidebarLink();
  };
  if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', boot);
  else boot();
  new MutationObserver(() => addSidebarLink()).observe(document.body, { childList: true, subtree: true });
})();
</script>

