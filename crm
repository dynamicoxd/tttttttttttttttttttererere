            custom_attributes: {
              empresa: empresaInput.value.trim(),
              valor: Number(valorInput.value) || 0,
              descricao: card.descricao || '',
              tags: card.tags || ''
            }
          };
          try {
            if (Number.isFinite(contactId)) {
              await this.api().contacts.update(contactId, payload);
              Object.values(this.data).forEach(column => {
                column.cards.forEach(item => {
                  if (item.id === card.id) {
                    item.cliente = payload.name;
                    item.empresa = payload.custom_attributes.empresa;
                    item.valor = payload.custom_attributes.valor;
                    item.descricao = payload.custom_attributes.descricao;
                    item.tags = payload.custom_attributes.tags;
                  }
                });
              });
            }
            this.saveLocal();
            this.render();
            alert('Informações salvas');
          } catch (err) { alert(`Falha ao salvar: ${err.body || err.message}`); }
        });

        on(openBtn, 'click', async () => { await this.openConversation(card, columnId); });

        on(addNoteBtn, 'click', async () => {
          const content = noteContent.value.trim();
          if (!content) return;
          if (!Number.isFinite(contactId)) { alert('Sem contato associado ao lead.'); return; }
          try { await this.api().contacts.notes(contactId, content); noteContent.value=''; await loadNotes(); }
          catch (err) { alert(`Erro ao adicionar nota: ${err.body || err.message}`); }
        });

        on(sendToLeadsBtn, 'click', async () => {
          await this.moveCard(columnId, 'leads', card.id, 0);
          const cid = Number(card.contactId);
          const conv = Number(card.conversationId);
