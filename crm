          const action = btn.getAttribute('data-action');

          if (action === 'view') {
            const it = this.getSchedules(card).find(x => x.id === id);
            if (!it) return;
            alert(`Agendamento #${it.id}\n\nQuando: ${new Date(it.sendAtIso).toLocaleString()}\nStatus: ${it.status}\n\nMensagem:\n${it.text || '(sem texto)'}`);
          }
          if (action === 'cancel') {
            if (!confirm('Cancelar este agendamento?')) return;
            try {
              const payload = {
                action: 'cancel',
                scheduleId: id,
                accountId: this.accountId,
                conversationId: Number(card.conversationId) || null,
                contactId: Number(card.contactId) || null
              };
              const res = await fetch(CONFIG.schedulerWebhookUrl, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(payload)
              });
              if (!res || (res.type !== 'opaque' && !res.ok)) {
                const txt = res ? await res.text().catch(()=> '') : '';
                throw new Error('Falha ao cancelar: ' + (res?.status || '') + ' ' + txt);
              }
              this.markScheduleStatus(card, id, 'canceled');
              renderScheduled();
