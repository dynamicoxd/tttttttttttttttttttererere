        const cacheKey = keyFor(this.accountId, `conv:${contactId}`);
        const stageHint = stage || this.getStageForContact(contactId) || 'leads';

        const finalize = async convId => {
          const n = Number(convId);
          if (!Number.isFinite(n)) return null;
          localStorage.setItem(cacheKey, String(n));
          this.applyConversationToCards(contactId, n);
          await this.setContactStageLabel(contactId, stageHint);
          await this.setConversationStageLabel(n, stageHint);
          return n;
        };

        const cached = localStorage.getItem(cacheKey);
        if (Number.isFinite(Number(cached))) return await finalize(Number(cached));

        try {
          const convs = await this.api().contacts.conversations(contactId);
          const list = extractList(convs);
          const open = list.filter(c => String(c.status || c?.attributes?.status || '').toLowerCase() === 'open');
          const chosen = (open[0] || list[0]);
          if (chosen?.id) return await finalize(chosen.id);
        } catch (err) { console.warn('Falha ao buscar conversas do contato', err); }

        if (!CONFIG.allowAutoCreateConversation) return null;

        const inboxId = this.pickInboxIdForCreate?.() || null;
        if (!Number.isFinite(Number(inboxId))) return null;

        const payload = {
          inbox_id: Number(inboxId),
          contact_id: contactId,
          source_id: `kanban-${contactId}-${Date.now()}-${Math.random().toString(16).slice(2, 8)}`,
