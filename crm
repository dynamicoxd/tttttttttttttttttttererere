<script>
(function () {
  // ====== CONFIG RÁPIDO ======
  const CONFIG = {
    baseUrl: location.origin,
    token: 'MZiA3XsZF4R3MnZdYCadEJJg', // troque se precisar
    schedulerWebhookUrl: 'https://n8n.g3growth.com.br/webhook/chatwoot',
    fixedTimezone: 'America/Sao_Paulo'
  };

  // ====== UI VARS ======
  const UI = { btnH: 32, padY: 6, padX: 14 };

  // ====== HELPERS ======
  const $ = (s, r=document) => { try { return r.querySelector(s); } catch { return null; } };
  const $$ = (s, r=document) => { try { return Array.from(r.querySelectorAll(s)); } catch { return []; } };
  const on = (el, ev, fn, opts) => { if (!el) return; const def=/^(touchstart|touchmove|wheel)$/.test(ev)?{passive:true}:undefined; el.addEventListener(ev, fn, opts??def); };
  const nrm = s => (s||'').toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g,'');
  const nowMs = () => Date.now();
  const isFuture = (iso) => { const t = new Date(iso).getTime(); return Number.isFinite(t) && t > nowMs(); };

  const detectAccountId = () => { const m=(location.pathname||'').match(/\/accounts\/(\d+)/); return m?Number(m[1]):NaN; };
  const detectConversationId = () => { const m=(location.pathname||'').match(/\/conversations\/(\d+)/); return m?Number(m[1]):NaN; };

  function normalizePhone(raw){
    if (!raw) return '';
    const digits = String(raw).replace(/[^\d+]/g,'');
    if (!digits) return '';
    if (digits.startsWith('+')) return digits;
    const only = digits.replace(/\D/g,'');
    if (only.length >= 10 && only.length <= 13 && !only.startsWith('55')) return '+55' + only;
    if (only.length >= 10 && only.length <= 13 && only.startsWith('55')) return '+' + only;
    return '+' + only;
  }

  function scrapePhoneFromUI(){
    const textNodes = [];
    const roots = [document.body, $('[data-testid*="contact" i]'), $('[data-testid*="sidebar" i]')].filter(Boolean);
    roots.forEach(root => {
      $$('*', root).slice(0, 2000).forEach(el => {
        const t = (el.innerText || el.textContent || '').trim();
        if (t) textNodes.push(t);
      });
    });
    const big = textNodes.join(' ');
    const m = big.match(/(\+?\d[\d\s().-]{8,}\d)/);
    if (!m) return '';
    return normalizePhone(m[1]);
  }

  function pickBestPhone(contact, conv){
    const tryPaths = [
      contact?.phone_number,
      contact?.additional_attributes?.phone_number,
      contact?.additional_attributes?.wa_id,
      contact?.additional_attributes?.whatsapp,
      contact?.additional_attributes?.telefone,
      contact?.custom_attributes?.phone,
      contact?.custom_attributes?.whatsapp,
      contact?.custom_attributes?.telefone,
      contact?.identifier,
      conv?.meta?.sender?.phone_number,
      conv?.meta?.contact?.phone_number,
      conv?.contact?.phone_number
    ].filter(Boolean);
    for (const cand of tryPaths) { const n = normalizePhone(cand); if (n) return n; }
    const scraped = scrapePhoneFromUI(); if (scraped) return scraped;
    return '';
  }

  function makeAPI(accountId){
    const base = (CONFIG.baseUrl.replace(/\/+$/,'') + '/api/v1/accounts/' + accountId);
    const headers = {
      'Content-Type': 'application/json',
      'Accept': 'application/json',
      'api_access_token': CONFIG.token,
      'Authorization': `Bearer ${CONFIG.token}`
    };
    async function req(path, opts={}){
      const url = base + path;
      const init = { credentials:'include', headers, ...opts };
      let res = await fetch(url, init);
      if ((res.status===401 || res.status===403) && CONFIG.token) {
        const sep = url.includes('?') ? '&' : '?';
        res = await fetch(url+sep+'api_access_token='+encodeURIComponent(CONFIG.token), init);
      }
      const ct = res.headers.get('content-type') || '';
      if (!res.ok) {
        const e = new Error(`${opts.method||'GET'} ${path} -> ${res.status}`);
        try { e.body = await res.text(); } catch {}
        throw e;
      }
      return ct.includes('application/json') ? res.json() : null;
    }
    return { conversations: { get: id => req(`/conversations/${id}`) }, contacts: { get: id => req(`/contacts/${id}`) } };
  }

  // ====== STORAGE LOCAL DE AGENDAMENTOS ======
  const SCHED_KEY = 'cw:schedules:v2';
  const loadAllSchedules = () => { try { return JSON.parse(localStorage.getItem(SCHED_KEY) || '{}') || {}; } catch { return {}; } };
  const saveAllSchedules = (obj) => { try { localStorage.setItem(SCHED_KEY, JSON.stringify(obj || {})); } catch {} };
  const keyFor = (accId, convId) => `${accId}:${convId}`;
  const getList = (accId, convId) => (loadAllSchedules()[keyFor(accId, convId)] || []).slice();
  const setList = (accId, convId, list) => { const all = loadAllSchedules(); all[keyFor(accId, convId)] = list.slice(); saveAllSchedules(all); };
  const addSchedule = (accId, convId, item) => { const l=getList(accId, convId); const i=l.findIndex(x=>x.id===item.id); if(i>=0) l[i]=item; else l.push(item); l.sort((a,b)=> new Date(a.sendAtIso)-new Date(b.sendAtIso)); setList(accId, convId, l); };
  const markStatus = (accId, convId, id, status) => { const l=getList(accId, convId); const it=l.find(x=>x.id===id); if(it){ it.status=status; setList(accId, convId, l);} };
  function cleanupOld(){
    const all = loadAllSchedules();
    const cutoff = Date.now() - 7*24*60*60*1000;
    let changed=false;
    Object.keys(all).forEach(k=>{
      const arr = all[k]||[];
      arr.forEach(s=>{
        const t = new Date(s.sendAtIso).getTime();
        if (s.status==='scheduled' && Number.isFinite(t) && t <= Date.now()) { s.status='sent'; changed=true; }
      });
      const filtered = arr.filter(s=>{
        if (s.status === 'scheduled') return true;
        const t = new Date(s.sendAtIso).getTime();
        return !(Number.isFinite(t) && t < cutoff);
      });
      if (filtered.length !== arr.length) { all[k]=filtered; changed=true; }
    });
    if (changed) saveAllSchedules(all);
  }
  cleanupOld(); setInterval(cleanupOld, 60*1000);

  // ====== AGENDADOR NO TOP LAYER (DIALOG) ======
  function openSchedulerDialog(card){
    const old = document.getElementById('scheduler-dialog'); if (old) old.remove();

    const isDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
    const bg     = isDark ? '#0f172a' : '#ffffff';
    const fgTitle= isDark ? '#ffffff' : '#0f172a';
    const subtle = isDark ? '#94a3b8' : '#64748b';
    const bdr    = isDark ? '#334155' : '#e2e8f0';
    const inputBg= isDark ? '#0b1220' : '#ffffff';
    const inputFg= isDark ? '#ffffff' : '#0f172a';
    const isoLocal = new Date(Date.now()+5*60*1000).toISOString().slice(0,16);

    const dlg = document.createElement('dialog');
    dlg.id = 'scheduler-dialog';
    dlg.style.cssText = 'padding:0;border:none;border-radius:12px;max-width:700px;width:clamp(320px,92vw,700px);background:'+bg+';color:'+fgTitle+';';
    const style = document.createElement('style');
    style.textContent = `
      #scheduler-dialog::backdrop { background: rgba(0,0,0,.4); }
      #scheduler-dialog .hdr{display:flex;justify-content:space-between;align-items:center;padding:12px 14px;border-bottom:1px solid ${bdr};font-weight:800}
      #scheduler-dialog .bd{padding:12px 14px;color:${inputFg}}
      #scheduler-dialog .row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
