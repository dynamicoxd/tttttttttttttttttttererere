      // === Adicionar existentes ===
      async addCardFromContact(contactId, stage = 'leads') {
        try {
          const idNum = Number(contactId);
          if (!Number.isFinite(idNum) || idNum <= 0) throw new Error('ID inválido');

          this.ignoredContacts.delete(String(idNum));
          this.saveIgnored();

          const c = await this.api().contacts.get(idNum);

          const get = (o, path, dflt=null) => path.split('.').reduce((a,k)=> (a && a[k]!=null)? a[k] : dflt, o);
          const cid = get(c, 'id') ?? get(c, 'payload.id') ?? get(c, 'payload.contact.id') ?? get(c, 'data.id');
          if (!cid) { alert('Contato não encontrado.'); return null; }

          const name = get(c, 'name') ?? get(c, 'identifier') ?? get(c, 'payload.name') ?? get(c, 'payload.contact.name') ?? `Contato ${cid}`;
          const identifier = get(c, 'identifier') ?? get(c, 'payload.identifier') ?? '';
          const labels = get(c, 'labels', []) ?? get(c, 'payload.labels', []) ?? get(c, 'payload.contact.labels', []) ?? [];
          const attrs = get(c, 'custom_attributes', {}) ?? get(c, 'payload.custom_attributes', {}) ?? get(c, 'payload.contact.custom_attributes', {}) ?? {};
          const email = get(c, 'email') ?? '';
          const phones = extractPhonesFromContact(c);

          let convId = null, inboxId = null;
          try {
            const convs = await this.api().contacts.conversations(cid);
            const list = extractList(convs) || [];
            const open = list.filter(x => String(x.status || get(x,'attributes.status','')).toLowerCase()==='open');
            const chosen = open[0] || list[0];
            if (chosen?.id) { convId = Number(chosen.id); inboxId = chosen.inbox_id || chosen.inboxId || null; }
            if (convId) { this.ignoredConversations.delete(String(convId)); this.saveIgnored(); }
          } catch {}

          Object.values(this.data).forEach(col => {
            const i = col.cards.findIndex(k => String(k.contactId) === String(cid));
            if (i > -1) col.cards.splice(i, 1);
          });

          const tags = (labels || []).filter(l => !isStage(l)).join(', ');
          const card = {
            id: String(cid),
            contactId: String(cid),
            conversationId: convId ? String(convId) : null,
            _inboxId: inboxId || null,
            cliente: name || identifier || 'Sem nome',
            empresa: attrs.empresa || '',
            valor: Number(attrs.valor || 0),
            descricao: attrs.descricao || '',
            tags,
            stage,
            email: email || '',
            phone: phones[0] || ''
          };

          await this.setContactStageLabel(cid, stage);
          if (convId) await this.setConversationStageLabel(convId, stage);

          (this.data[stage]?.cards || []).unshift(card);
          this.saveLocal();
          this.render();
          return card;
        } catch (e) {
          alert(`Falha ao adicionar contato: ${e.body || e.message}`);
          return null;
        }
      },

      async addCardFromConversation(conversationId, stage = 'leads') {
        try {
          const idNum = Number(conversationId);
          if (!Number.isFinite(idNum) || idNum <= 0) throw new Error('ID de conversa inválido');

          this.ignoredConversations.delete(String(idNum));
          this.saveIgnored();

          const conv = await this.api().conversations.get(idNum);
          const contact = conv?.meta?.sender || conv?.contact || conv?.meta?.contact || {};
          const contactId = Number(contact?.id);

          if (!Number.isFinite(contactId) || contactId <= 0) {
            alert('Conversa sem contato associado.');
            return null;
          }

          this.ignoredContacts.delete(String(contactId));
          this.saveIgnored();

          const card = await this.addCardFromContact(contactId, stage);
          if (card) {
            await this.setConversationStageLabel(idNum, stage);
            this.applyConversationToCards(contactId, idNum);
            this.saveLocal();
            this.render();
            return card;
          } else {
            return null;
          }
        } catch (e) {
          alert(`Falha ao adicionar conversa: ${e.body || e.message}`);
          return null;
        }
      },

