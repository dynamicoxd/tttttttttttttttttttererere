        on(hideBtn, 'click', () => {
          const msg = 'Isso apenas oculta localmente. Confirmar?';
          if (confirm(msg)) { this.ignoreCard(card); closeModal(); }
        });

        on(scheduleBtn, 'click', () => this.showScheduleModal(card));
