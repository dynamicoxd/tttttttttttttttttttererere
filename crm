          message: { content: `Conversa criada automaticamente pelo Kanban CRM (${stageHint}).` }
        };

        try {
          const conv = await this.api().conversations.create(payload);
          if (conv?.id) return await finalize(conv.id);
        } catch (err) { console.warn('Falha ao criar conversa', err); }
        return null;
