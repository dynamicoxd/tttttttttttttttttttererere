sweepSentStatusesCW(){
  const all = this.loadCWAll();
  let changed = false;
  Object.keys(all).forEach(k=>{
    const arr = Array.isArray(all[k]) ? all[k] : [];
    arr.forEach(s=>{
      const t = new Date(s.sendAtIso).getTime();
      if (s.status === 'scheduled' && Number.isFinite(t) && t <= Date.now()){
        s.status = 'sent'; changed = true;
      }
    });
    all[k] = arr; // garante array
  });
  if (changed) this.saveCWAll(all);
},

addOrUpdateCWSchedule(accId, convId, item) {
  // lista atual dessa conversa
  const list = this.getCWSchedulesByConv(accId, convId);
  const idx = list.findIndex(s => s.id === item.id);

  // merge/insere
  const nowIso = new Date().toISOString();
  const normalized = {
    id: item.id,
    sendAtIso: item.sendAtIso,
    text: item.text || '',
    status: item.status || 'scheduled',
    createdAt: item.createdAt || nowIso,
    updatedAt: nowIso
  };

  if (idx > -1) list[idx] = { ...list[idx], ...normalized };
  else list.push(normalized);

  // salva e avisa outras abas
  this.setCWSchedulesByConv(accId, convId, list);
  try { localStorage.setItem('cw:schedules:v2:evt', String(Date.now())); } catch {}
},

